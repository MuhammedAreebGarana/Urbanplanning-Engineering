 <!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UrbanPolicy — Policy Simulation Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,400;0,500;1,400&family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --ink:#0A0F1A;
  --ink2:#1E2740;
  --ink3:#2D3A5C;
  --surface:#F4F6FB;
  --surface2:#E8ECF5;
  --surface3:#D4DAF0;
  --accent:#2563EB;
  --accent2:#1D4ED8;
  --accentg:#10B981;
  --accentr:#EF4444;
  --accenty:#F59E0B;
  --border:rgba(37,99,235,0.15);
  --border2:rgba(37,99,235,0.3);
  --glow:rgba(37,99,235,0.2);
  --font-head:'Syne',sans-serif;
  --font-body:'Inter',sans-serif;
  --font-mono:'DM Mono',monospace;
}

html, body {
  font-family: var(--font-body);
  background: var(--ink);
  color: #fff;
  overflow: hidden;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ─────────────────────────────
   TOP NAV BAR
───────────────────────────── */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  height: 52px;
  background: rgba(10,15,26,0.98);
  border-bottom: 1px solid var(--border2);
  flex-shrink: 0;
  z-index: 1000;
  position: relative;
}

.logo {
  font-family: var(--font-head);
  font-size: 16px;
  font-weight: 800;
  letter-spacing: -0.5px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.logo-mark {
  width: 28px;
  height: 28px;
  background: var(--accent);
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
  flex-shrink: 0;
}

.logo-text span { color: var(--accent); }

.nav-pills { display: flex; gap: 4px; }

.npill {
  font-family: var(--font-mono);
  font-size: 11px;
  padding: 5px 12px;
  border-radius: 4px;
  border: 1px solid transparent;
  cursor: pointer;
  color: rgba(255,255,255,0.5);
  background: transparent;
  transition: all 0.15s;
  letter-spacing: 0.02em;
}

.npill.active,
.npill:hover {
  border-color: var(--border2);
  color: #fff;
  background: rgba(37,99,235,0.1);
}

.status-bar {
  display: flex;
  align-items: center;
  gap: 12px;
}

.status-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--accentg);
  animation: pulse 2s infinite;
}

.status-txt {
  font-family: var(--font-mono);
  font-size: 10px;
  color: rgba(255,255,255,0.5);
  letter-spacing: 0.05em;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.4; }
}

/* ─────────────────────────────
   MAIN WORKSPACE LAYOUT
───────────────────────────── */
.workspace {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* ─────────────────────────────
   LEFT PANEL — Policy Library
───────────────────────────── */
.left-panel {
  width: 280px;
  flex-shrink: 0;
  background: rgba(10,15,26,0.95);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.panel-section { border-bottom: 1px solid var(--border); }

.panel-head {
  padding: 12px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}

.panel-head-txt {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
}

.panel-head-ico {
  font-size: 10px;
  color: rgba(255,255,255,0.3);
}

.panel-body { padding: 8px 12px 12px; }

/* Scrollable left panel */
.left-scroll { flex: 1; overflow-y: auto; }
.left-scroll::-webkit-scrollbar { width: 3px; }
.left-scroll::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 2px;
}

/* Policy category labels */
.policy-cat { margin-bottom: 8px; }

.policy-cat-label {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.08em;
  color: rgba(255,255,255,0.3);
  padding: 4px 4px;
  text-transform: uppercase;
}

/* Policy cards */
.policy-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 8px;
  padding: 10px 12px;
  margin-bottom: 6px;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}

.policy-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  border-radius: 2px 0 0 2px;
}

.policy-card.green::before  { background: var(--accentg); }
.policy-card.blue::before   { background: var(--accent); }
.policy-card.amber::before  { background: var(--accenty); }
.policy-card.red::before    { background: var(--accentr); }

.policy-card:hover {
  background: rgba(37,99,235,0.08);
  border-color: var(--border2);
}

.policy-card.enacted {
  background: rgba(16,185,129,0.06);
  border-color: rgba(16,185,129,0.2);
}

.pc-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
}

.pc-name {
  font-size: 12px;
  font-weight: 500;
  color: rgba(255,255,255,0.85);
  line-height: 1.3;
}

.pc-badge {
  font-family: var(--font-mono);
  font-size: 8px;
  padding: 2px 6px;
  border-radius: 3px;
  flex-shrink: 0;
  margin-top: 1px;
}

.badge-enacted {
  background: rgba(16,185,129,0.15);
  color: #10B981;
  border: 1px solid rgba(16,185,129,0.3);
}

.badge-draft {
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.35);
  border: 1px solid rgba(255,255,255,0.08);
}

.pc-meta {
  margin-top: 4px;
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255,255,255,0.3);
  letter-spacing: 0.02em;
}

.enact-btn {
  width: 100%;
  margin-top: 8px;
  padding: 6px;
  border-radius: 5px;
  border: 1px solid rgba(37,99,235,0.3);
  background: rgba(37,99,235,0.1);
  color: rgba(255,255,255,0.7);
  font-family: var(--font-mono);
  font-size: 9px;
  cursor: pointer;
  letter-spacing: 0.05em;
  transition: all 0.2s;
}

.enact-btn:hover {
  background: rgba(37,99,235,0.25);
  border-color: rgba(37,99,235,0.6);
  color: #fff;
}

.enact-btn.active-btn {
  background: rgba(16,185,129,0.15);
  border-color: rgba(16,185,129,0.4);
  color: #10B981;
}

/* Layer controls */
.layer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6px 4px;
  border-radius: 6px;
  cursor: pointer;
  transition: background 0.15s;
}

.layer-row:hover { background: rgba(255,255,255,0.04); }

.layer-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.layer-dot {
  width: 10px;
  height: 10px;
  border-radius: 2px;
  flex-shrink: 0;
}

.layer-name {
  font-size: 12px;
  color: rgba(255,255,255,0.65);
}

.toggle {
  width: 30px;
  height: 16px;
  border-radius: 8px;
  background: rgba(255,255,255,0.1);
  position: relative;
  cursor: pointer;
  transition: background 0.2s;
  border: 1px solid rgba(255,255,255,0.1);
}

.toggle.on {
  background: rgba(37,99,235,0.6);
  border-color: rgba(37,99,235,0.8);
}

.toggle::after {
  content: '';
  width: 10px;
  height: 10px;
  border-radius: 5px;
  background: #fff;
  position: absolute;
  top: 2px;
  left: 2px;
  transition: transform 0.2s;
}

.toggle.on::after { transform: translateX(14px); }

/* ─────────────────────────────
   CENTER MAP
───────────────────────────── */
.map-area {
  flex: 1;
  position: relative;
  overflow: hidden;
}

#map {
  width: 100%;
  height: 100%;
}

/* Map HUD — Top Left */
.map-hud-tl {
  position: absolute;
  top: 16px;
  left: 16px;
  z-index: 500;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.hud-box {
  background: rgba(10,15,26,0.9);
  border: 1px solid var(--border2);
  border-radius: 8px;
  padding: 10px 14px;
  backdrop-filter: blur(8px);
}

.hud-title {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  margin-bottom: 6px;
}

.hud-metric {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: baseline;
}

.hud-val {
  font-family: var(--font-head);
  font-size: 20px;
  font-weight: 700;
  color: #fff;
}

.hud-sub {
  font-family: var(--font-mono);
  font-size: 10px;
  color: rgba(255,255,255,0.4);
}

/* Map HUD — Top Right */
.map-hud-tr {
  position: absolute;
  top: 16px;
  right: 16px;
  z-index: 500;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.mode-sel {
  display: flex;
  gap: 4px;
  background: rgba(10,15,26,0.9);
  border: 1px solid var(--border2);
  border-radius: 8px;
  padding: 4px;
}

.mode-btn {
  font-family: var(--font-mono);
  font-size: 9px;
  padding: 5px 10px;
  border-radius: 5px;
  border: none;
  background: transparent;
  color: rgba(255,255,255,0.4);
  cursor: pointer;
  letter-spacing: 0.05em;
  transition: all 0.15s;
  text-transform: uppercase;
}

.mode-btn.active {
  background: var(--accent);
  color: #fff;
}

.simulation-badge {
  background: rgba(10,15,26,0.9);
  border: 1px solid rgba(16,185,129,0.3);
  border-radius: 8px;
  padding: 8px 14px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.sim-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #10B981;
  animation: pulse 1.5s infinite;
}

.sim-txt {
  font-family: var(--font-mono);
  font-size: 10px;
  color: #10B981;
  letter-spacing: 0.05em;
}

/* ─────────────────────────────
   RIGHT PANEL — Simulation
───────────────────────────── */
.right-panel {
  width: 300px;
  flex-shrink: 0;
  background: rgba(10,15,26,0.95);
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.rp-head {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.rp-title {
  font-family: var(--font-head);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: -0.3px;
  margin-bottom: 2px;
}

.rp-sub {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.05em;
}

.rp-body {
  flex: 1;
  overflow-y: auto;
  padding: 12px;
}

.rp-body::-webkit-scrollbar { width: 3px; }
.rp-body::-webkit-scrollbar-track { background: transparent; }
.rp-body::-webkit-scrollbar-thumb {
  background: var(--border2);
  border-radius: 2px;
}

/* Active policy detail card */
.active-policy-card {
  background: rgba(16,185,129,0.05);
  border: 1px solid rgba(16,185,129,0.15);
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 12px;
}

.apc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.apc-name {
  font-family: var(--font-head);
  font-size: 13px;
  font-weight: 700;
}

.apc-status {
  font-family: var(--font-mono);
  font-size: 8px;
  background: rgba(16,185,129,0.15);
  color: #10B981;
  border: 1px solid rgba(16,185,129,0.3);
  border-radius: 3px;
  padding: 2px 7px;
  letter-spacing: 0.08em;
}

/* Factor grid */
.factor-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 10px;
}

.factor-box {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 7px;
  padding: 8px 10px;
}

.fb-label {
  font-family: var(--font-mono);
  font-size: 8px;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 3px;
}

.fb-val {
  font-family: var(--font-head);
  font-size: 16px;
  font-weight: 700;
}

.fb-val.up      { color: #10B981; }
.fb-val.down    { color: #EF4444; }
.fb-val.neutral { color: var(--accent); }

.fb-trend {
  font-family: var(--font-mono);
  font-size: 9px;
  margin-top: 1px;
  color: rgba(255,255,255,0.35);
}

/* Implementation todo list */
.todo-section { margin-bottom: 12px; }

.todo-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.todo-title {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255,255,255,0.4);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.todo-count {
  font-family: var(--font-mono);
  font-size: 9px;
  background: rgba(37,99,235,0.15);
  color: var(--accent);
  border-radius: 3px;
  padding: 1px 6px;
}

.todo-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 9px 10px;
  border-radius: 7px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.05);
  margin-bottom: 5px;
  cursor: pointer;
  transition: all 0.15s;
}

.todo-item:hover {
  background: rgba(37,99,235,0.06);
  border-color: var(--border);
}

.todo-item.done { opacity: 0.5; }

.todo-check {
  width: 16px;
  height: 16px;
  border-radius: 4px;
  border: 1px solid rgba(255,255,255,0.2);
  flex-shrink: 0;
  margin-top: 1px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 9px;
  transition: all 0.2s;
}

.todo-item.done .todo-check {
  background: var(--accentg);
  border-color: var(--accentg);
  color: #fff;
}

.todo-content { flex: 1; }

.todo-txt {
  font-size: 11px;
  color: rgba(255,255,255,0.75);
  line-height: 1.4;
}

.todo-item.done .todo-txt {
  text-decoration: line-through;
  color: rgba(255,255,255,0.3);
}

.todo-meta {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255,255,255,0.25);
  margin-top: 2px;
}

.todo-priority {
  font-family: var(--font-mono);
  font-size: 8px;
  padding: 1px 5px;
  border-radius: 3px;
  flex-shrink: 0;
  margin-top: 2px;
}

.pri-high {
  background: rgba(239,68,68,0.12);
  color: #EF4444;
  border: 1px solid rgba(239,68,68,0.2);
}

.pri-mid {
  background: rgba(245,158,11,0.12);
  color: #F59E0B;
  border: 1px solid rgba(245,158,11,0.2);
}

.pri-low {
  background: rgba(37,99,235,0.12);
  color: #60A5FA;
  border: 1px solid rgba(37,99,235,0.2);
}

/* LLM output section */
.llm-section {
  background: rgba(37,99,235,0.04);
  border: 1px solid rgba(37,99,235,0.12);
  border-radius: 10px;
  padding: 12px;
}

.llm-head {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}

.llm-ico {
  width: 22px;
  height: 22px;
  background: rgba(37,99,235,0.15);
  border-radius: 5px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
}

.llm-label {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255,255,255,0.4);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.llm-output {
  font-size: 11px;
  color: rgba(255,255,255,0.65);
  line-height: 1.7;
  font-style: italic;
}

.llm-cursor {
  display: inline-block;
  width: 6px;
  height: 11px;
  background: var(--accent);
  margin-left: 2px;
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 50%  { opacity: 1; }
  51%,100% { opacity: 0; }
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 40px 20px;
}

.empty-ico {
  font-size: 32px;
  margin-bottom: 12px;
  opacity: 0.3;
}

.empty-txt {
  font-family: var(--font-mono);
  font-size: 10px;
  color: rgba(255,255,255,0.25);
  letter-spacing: 0.05em;
  line-height: 1.8;
}

/* ─────────────────────────────
   BOTTOM STATS BAR
───────────────────────────── */
.stats-bar {
  display: flex;
  align-items: center;
  border-top: 1px solid var(--border);
  height: 36px;
  flex-shrink: 0;
  background: rgba(10,15,26,0.98);
}

.stat-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 0 12px;
  border-right: 1px solid var(--border);
}

.stat-item:last-child { border-right: none; }

.stat-label {
  font-family: var(--font-mono);
  font-size: 9px;
  color: rgba(255,255,255,0.3);
  letter-spacing: 0.06em;
}

.stat-val {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 500;
  color: rgba(255,255,255,0.7);
}

.stat-val.green { color: #10B981; }
.stat-val.blue  { color: #60A5FA; }
.stat-val.amber { color: #F59E0B; }

/* ─────────────────────────────
   NOTIFICATION TOAST
───────────────────────────── */
.toast {
  position: fixed;
  bottom: 48px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(10,15,26,0.96);
  border: 1px solid rgba(16,185,129,0.4);
  border-radius: 8px;
  padding: 10px 20px;
  font-family: var(--font-mono);
  font-size: 11px;
  color: #10B981;
  letter-spacing: 0.04em;
  z-index: 2000;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
  white-space: nowrap;
}

.toast.show { opacity: 1; }
</style>
</head>
<body>

<!-- ═══════════════════════════════
     TOP BAR
═══════════════════════════════ -->
<div class="topbar">
  <div class="logo">
    <div class="logo-mark">⬡</div>
    <div class="logo-text">
      URBAN<span>POLICY</span>
      <span style="font-size:10px;color:rgba(255,255,255,0.25);font-weight:400;letter-spacing:0.05em">
        / policy simulation
      </span>
    </div>
  </div>

  <div class="nav-pills">
    <div class="npill active">simulation</div>
    <div class="npill">analytics</div>
    <div class="npill">scenarios</div>
    <div class="npill">reports</div>
  </div>

  <div class="status-bar">
    <div class="status-dot"></div>
    <div class="status-txt">LLM ENGINE ONLINE · OSM CONNECTED</div>
    <div style="width:1px;height:16px;background:var(--border);margin:0 4px"></div>
    <div class="status-txt" id="clock">--:--:--</div>
  </div>
</div>

<!-- ═══════════════════════════════
     MAIN WORKSPACE
═══════════════════════════════ -->
<div class="workspace">

  <!-- ─────────────────────────
       LEFT PANEL: Policy Library
  ───────────────────────── -->
  <div class="left-panel">

    <div class="panel-section">
      <div class="panel-head">
        <span class="panel-head-txt">Policy Library</span>
        <span class="panel-head-ico">▼</span>
      </div>
    </div>

    <div class="left-scroll">
      <div class="panel-body">

        <!-- Land Use -->
