/* ── State ── */
const activePolygons = {};
const enactedPolicies = new Set();
let enactedCount = 0;
let currentPolicy = null;

/* ── Mode selector ── */
function setMode(btn, mode) {
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

/* ── Toast notification ── */
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

/* ── Animate a stat counter ── */
function animVal(elId, from, to, suffix, neg = false) {
  const el = document.getElementById(elId);
  const dur = 1500, steps = 30, inc = (to - from) / steps;
  let cur = from, step = 0;
  const iv = setInterval(() => {
    cur += inc;
    step++;
    if (step >= steps) { cur = to; clearInterval(iv); }
    el.textContent = (neg ? '-' : '') + Math.round(Math.abs(cur)) + suffix;
  }, dur / steps);
}

/* ── Update bottom stats on enact ── */
function updateStats(id) {
  if (id === 1) { animVal('s-walk', 72, 82, ''); }
  if (id === 2) { animVal('s-aqi', 84, 94, ''); animVal('s-co', 12, 18, '%', true); }
  if (id === 3) { animVal('s-tc', 67, 78, '%'); }
  if (id === 5) { animVal('s-haf', 41, 54, '%'); }
}

/* ── Enact / select a policy ── */
function enactPolicy(id) {
  const p = policyData[id];
  const alreadyEnacted = enactedPolicies.has(id);

  if (!alreadyEnacted) {
    enactedPolicies.add(id);
    enactedCount++;

    // Update left panel badges
    document.getElementById('badge-' + id).textContent = 'ENACTED';
    document.getElementById('badge-' + id).className = 'pc-badge badge-enacted';
    document.getElementById('btn-' + id).textContent = '✓ ENACTED';
    document.getElementById('btn-' + id).className = 'enact-btn active-btn';
    document.getElementById('pc-' + id).classList.add('enacted');

    // Update stat counters
    document.getElementById('s-ep').textContent = enactedCount;
    document.getElementById('hud-pol').textContent = enactedCount;

    // Draw zone polygons on the OSM map
    const zd = policyZones[id];
    if (zd) {
      const polys = zd.zones.map(coords =>
        L.polygon(coords, {
          color: zd.color,
          fillColor: zd.color,
          fillOpacity: 0.18,
          weight: 2,
          dashArray: '6 4'
        })
        .addTo(map)
        .bindPopup(
          `<b style="font-family:monospace;font-size:11px">${p.name}</b>
           <br><span style="font-size:10px;opacity:0.7">Status: ENACTED</span>`
        )
      );
      activePolygons[id] = polys;
    }

    updateStats(id);
    showToast(`✓ Policy enacted: ${p.name}`);
  }

  currentPolicy = id;
  showPolicyDetail(id);
}

/* ── Render right panel for selected policy ── */
function showPolicyDetail(id) {
  const p = policyData[id];
  const enacted = enactedPolicies.has(id);

  const factorBoxes = Object.values(p.factors).map(f => `
    <div class="factor-box">
      <div class="fb-label">${f.label}</div>
      <div class="fb-val ${f.dir}">${f.val}</div>
      <div class="fb-trend">${f.trend}</div>
    </div>
  `).join('');

  const doneCnt = p.todos.filter(t => t.done).length;

  const todos = p.todos.map((t, i) => `
    <div class="todo-item ${t.done ? 'done' : ''}" onclick="toggleTodo(${id}, ${i})">
      <div class="todo-check">${t.done ? '✓' : ''}</div>
      <div class="todo-content">
        <div class="todo-txt">${t.txt}</div>
        <div class="todo-meta">${t.zone}</div>
      </div>
      <div class="todo-priority ${t.pri === 'high' ? 'pri-high' : t.pri === 'mid' ? 'pri-mid' : 'pri-low'}">
        ${t.pri.toUpperCase()}
      </div>
    </div>
  `).join('');

  document.getElementById('rp-body').innerHTML = `
    <div class="active-policy-card">
      <div class="apc-header">
        <div class="apc-name">${p.name}</div>
        <div class="apc-status">${enacted ? 'ENACTED' : 'DRAFT'}</div>
      </div>
      <div class="factor-grid">${factorBoxes}</div>
    </div>

    <div class="todo-section">
      <div class="todo-head">
        <div class="todo-title">Implementation Tasks</div>
        <div class="todo-count">${doneCnt}/${p.todos.length} DONE</div>
      </div>
      ${todos}
    </div>

    <div class="llm-section">
      <div class="llm-head">
        <div class="llm-ico">◈</div>
        <div class="llm-label">UrbanLLM Simulation Analysis</div>
      </div>
      <div class="llm-output" id="llm-out"></div>
    </div>
  `;

  typeLLM(p.llm);
}

/* ── Typewriter animation for LLM output ── */
function typeLLM(text) {
  const el = document.getElementById('llm-out');
  if (!el) return;
  el.innerHTML = '<span class="llm-cursor"></span>';
  let i = 0;
  const iv = setInterval(() => {
    if (i >= text.length) { clearInterval(iv); return; }
    el.innerHTML = text.slice(0, ++i) + '<span class="llm-cursor"></span>';
    el.parentElement.scrollTop = el.parentElement.scrollHeight;
  }, 18);
}

/* ── Toggle todo item ── */
function toggleTodo(policyId, idx) {
  policyData[policyId].todos[idx].done = !policyData[policyId].todos[idx].done;
  showPolicyDetail(policyId);
}

/* ── Auto-preview first policy on load ── */
setTimeout(() => showPolicyDetail(1), 800);
