/* ═════════════════════════════════════
   INIT
═════════════════════════════════════ */
function init() {
  buildRegistryTable();
  buildScenarioCards();
  buildReportList();
  setTimeout(() => renderPolicyDetail(1), 400);
}

/* ═════════════════════════════════════
   CLOCK & TIMER
═════════════════════════════════════ */
function updateClock() {
  document.getElementById('clock').textContent = new Date().toTimeString().slice(0,8)+' PKT';
}
setInterval(updateClock,1000); updateClock();

setInterval(()=>{
  simSecs++;
  const h=Math.floor(simSecs/3600).toString().padStart(2,'0');
  const m=Math.floor((simSecs%3600)/60).toString().padStart(2,'0');
  const s=(simSecs%60).toString().padStart(2,'0');
  const t=`${h}:${m}:${s}`;
  document.getElementById('simtime').textContent=t;
  document.getElementById('s-time').textContent=t;
},1000);

/* ═════════════════════════════════════
   TOAST / MODAL
═════════════════════════════════════ */
function showToast(msg) {
  const el=document.getElementById('toast');
  el.textContent=msg; el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'),3000);
}
function openModal(id){document.getElementById(id).classList.add('show')}
function closeModal(id){document.getElementById(id).classList.remove('show')}

/* ═════════════════════════════════════
   PAGE NAVIGATION
═════════════════════════════════════ */
function showPage(name,tab) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.ntab').forEach(t=>t.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  tab.classList.add('active');
  if(name==='analytics') { setTimeout(initCharts,50); }
}

/* ═════════════════════════════════════
   OSM MAP — KARACHI
═════════════════════════════════════ */
// Karachi centre: 24.8607° N, 67.0011° E
const map = L.map('map',{zoomControl:false}).setView([24.8607,67.0011],12);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
  attribution:'© <a href="https://openstreetmap.org/copyright">OpenStreetMap</a> contributors',maxZoom:19
}).addTo(map);
L.control.zoom({position:'bottomright'}).addTo(map);

/* ─── GIS LAYER DATA — Karachi ─── */
function buildMapLayers() {
  /* Green Spaces — parks & coastal */
  const greenData = [
    { coords:[[24.8137,66.9889],[24.8165,66.9920],[24.8148,66.9950],[24.8118,66.9925]], label:'Hill Park' },
    { coords:[[24.8247,67.0280],[24.8268,67.0310],[24.8252,67.0338],[24.8228,67.0305]], label:'Safari Park' },
    { coords:[[24.8310,67.0200],[24.8335,67.0235],[24.8318,67.0260],[24.8290,67.0230]], label:'Bagh Ibn Qasim' },
  ];
  mapLayers.greenSpaces = L.layerGroup(greenData.map(d=>
    L.polygon(d.coords,{color:'#10B981',fillColor:'#10B981',fillOpacity:0.22,weight:1.5})
     .bindPopup(`<b style="font-family:monospace;font-size:11px">🌿 ${d.label}</b><br><span style="font-size:10px">Green Space Layer</span>`)
  )).addTo(map);

  /* Congestion Heat — major arteries */
  const congData = [
    { path:[[24.9200,67.0300],[24.9000,67.0300],[24.8800,67.0200],[24.8600,67.0100]], label:'Shahrah-e-Faisal', level:'CRITICAL' },
    { path:[[24.8700,67.0100],[24.8700,66.9900],[24.8600,66.9700]], label:'M.A. Jinnah Road', level:'HIGH' },
    { path:[[24.9300,67.0800],[24.9000,67.0700],[24.8800,67.0700]], label:'University Road', level:'HIGH' },
  ];
  mapLayers.congestion = L.layerGroup(congData.map(d=>
    L.polyline(d.path,{color: d.level==='CRITICAL'?'#EF4444':'#F59E0B',weight:5,opacity:0.65,dashArray: d.level==='CRITICAL'?null:'8 4'})
     .bindPopup(`<b style="font-family:monospace;font-size:11px">🚦 ${d.label}</b><br><span style="font-size:10px;color:${d.level==='CRITICAL'?'#EF4444':'#F59E0B'}">Congestion: ${d.level}</span>`)
  )).addTo(map);

  /* Zoning Districts */
  const zoneData = [
    { coords:[[24.8556,67.0140],[24.8620,67.0200],[24.8600,67.0280],[24.8530,67.0250],[24.8510,67.0160]], label:'Saddar Commercial', color:'#2563EB' },
    { coords:[[24.8150,66.9980],[24.8200,67.0060],[24.8175,67.0120],[24.8120,67.0080],[24.8100,67.0000]], label:'Clifton Residential', color:'#8B5CF6' },
    { coords:[[24.9020,67.0680],[24.9080,67.0780],[24.9050,67.0840],[24.8990,67.0790],[24.8960,67.0700]], label:'Gulshan Commercial', color:'#06B6D4' },
    { coords:[[24.8400,67.0850],[24.8460,67.0960],[24.8430,67.1020],[24.8360,67.0970],[24.8330,67.0880]], label:'Korangi Industrial', color:'#F59E0B' },
  ];
  mapLayers.zoning = L.layerGroup(zoneData.map(d=>
    L.polygon(d.coords,{color:d.color,fillColor:d.color,fillOpacity:0.12,weight:1.5,dashArray:'5 4'})
     .bindPopup(`<b style="font-family:monospace;font-size:11px">🏙️ ${d.label}</b><br><span style="font-size:10px">Zoning District</span>`)
  )).addTo(map);

  /* Density Overlay — heat circles */
  const densityPts = [
    [24.8607,67.0011,28000,'Saddar (Very High)'],[24.9200,67.0700,22000,'Gulshan (High)'],
    [24.8900,66.9700,32000,'Lyari (Very High)'],[24.9500,66.9900,18000,'Orangi (High)'],
    [24.8600,67.0800,15000,'Korangi (Medium)'],[24.8200,66.9700,12000,'Keamari (Medium)'],
  ];
  mapLayers.density = L.layerGroup(densityPts.map(d=>
    L.circle([d[0],d[1]],{radius:d[2],color:'#EF4444',fillColor:'#EF4444',fillOpacity:0.08,weight:1})
     .bindPopup(`<b style="font-family:monospace;font-size:11px">📊 ${d[3]}</b><br><span style="font-size:10px">Population Density Overlay</span>`)
  ));

  /* Transit Nodes — BRT stops + Circular Rwy */
  const transitNodes = [
    [24.9405,67.1065,'Surjani BRT Terminus','BRT'],[24.9200,67.0700,'Gulshan-e-Iqbal Hub','BRT'],
    [24.8925,67.0700,'University Road Station','BRT'],[24.8750,67.0600,'Nipa Chowrangi','BRT'],
    [24.8607,67.0100,'Saddar Terminal','BRT'],[24.8400,67.0200,'Keamari Ferry Point','FERRY'],
    [24.9100,67.1400,'Malir City Junction','BRT'],[24.9280,67.0970,'Gulshan Chowrangi','BRT'],
  ];
  mapLayers.transit = L.layerGroup(transitNodes.map(d=>{
    const color = d[3]==='BRT'?'#8B5CF6':'#06B6D4';
    const marker = L.circleMarker([d[0],d[1]],{radius:7,color:'#fff',fillColor:color,fillOpacity:0.9,weight:2});
    marker.bindPopup(`<b style="font-family:monospace;font-size:11px">🚌 ${d[2]}</b><br><span style="font-size:10px;color:${color}">${d[3]} Node</span>`);
    return marker;
  })).addTo(map);

  /* Flood Risk Zones */
  const floodData = [
    { coords:[[24.8700,66.9600],[24.8800,66.9700],[24.8750,66.9800],[24.8650,66.9750],[24.8600,66.9650]], label:'Lyari Riverbed — Critical Flood Risk', risk:'critical' },
    { coords:[[24.8200,66.9700],[24.8280,66.9800],[24.8250,66.9870],[24.8160,66.9830],[24.8130,66.9720]], label:'Keamari Coastal Zone — High Flood Risk', risk:'high' },
    { coords:[[24.9000,67.1200],[24.9080,67.1340],[24.9040,67.1420],[24.8960,67.1360],[24.8920,67.1220]], label:'Malir River Floodplain — High Risk', risk:'high' },
  ];
  mapLayers.flood = L.layerGroup(floodData.map(d=>
    L.polygon(d.coords,{color:d.risk==='critical'?'#EF4444':'#F59E0B',fillColor:d.risk==='critical'?'#EF4444':'#F59E0B',fillOpacity:0.18,weight:2,dashArray:'4 3'})
     .bindPopup(`<b style="font-family:monospace;font-size:11px">🌊 ${d.label}</b>`)
  ));
}

buildMapLayers();

/* ─── Toggle Layer Function ─── */
function toggleLayer(name) {
  layerState[name] = !layerState[name];
  const tog = document.getElementById('toggle-'+name);
  if (tog) tog.classList.toggle('on', layerState[name]);
  if (!mapLayers[name]) return;
  if (layerState[name]) { mapLayers[name].addTo(map); }
  else { map.removeLayer(mapLayers[name]); }
}

/* ─── Enacted policy zone polygons ─── */
const activePolygons = {};

/* ─── Map Modes ─── */
function setMapMode(mode, btn) {
  mapMode = mode;
  document.querySelectorAll('.mode-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');

  const tooltip = document.getElementById('draw-tooltip');

  if (mode==='draw') {
    tooltip.style.display='block';
    tooltip.textContent='Click to place zone vertices · Double-click to finish';
    map.getContainer().style.cursor='crosshair';
    // start draw
    drawPoints=[]; drawMarkers=[];
    map.on('click', onDrawClick);
    map.on('dblclick', onDrawFinish);
  } else {
    tooltip.style.display='none';
    map.getContainer().style.cursor='';
    map.off('click', onDrawClick);
    map.off('dblclick', onDrawFinish);
    if (mode==='measure') {
      tooltip.style.display='block';
      tooltip.textContent='Click to measure distance · Double-click to finish';
      map.getContainer().style.cursor='crosshair';
      measurePoints=[]; measureMarkers=[];
      if(measureLine){map.removeLayer(measureLine);measureLine=null;}
      measureMarkers.forEach(m=>map.removeLayer(m));
      map.on('click', onMeasureClick);
      map.on('dblclick', onMeasureFinish);
    } else {
      map.off('click', onMeasureClick);
      map.off('dblclick', onMeasureFinish);
      if(measureLine){map.removeLayer(measureLine);}
      measureMarkers.forEach(m=>map.removeLayer(m));
    }
  }
}

function onDrawClick(e) {
  if (mapMode!=='draw') return;
  drawPoints.push([e.latlng.lat, e.latlng.lng]);
  const m = L.circleMarker(e.latlng,{radius:4,color:'#2563EB',fillColor:'#2563EB',fillOpacity:0.9}).addTo(map);
  drawMarkers.push(m);
  if (drawPoints.length>1) {
    if (window._drawPreview) map.removeLayer(window._drawPreview);
    window._drawPreview = L.polyline(drawPoints,{color:'#2563EB',weight:2,dashArray:'5 3',opacity:0.7}).addTo(map);
  }
}

function onDrawFinish(e) {
  if (mapMode!=='draw' || drawPoints.length<3) { showToast('Draw at least 3 points to create a zone'); return; }
  map.off('click', onDrawClick);
  map.off('dblclick', onDrawFinish);
  if(window._drawPreview){map.removeLayer(window._drawPreview);}
  drawMarkers.forEach(m=>map.removeLayer(m));
  const poly = L.polygon(drawPoints,{color:'#2563EB',fillColor:'#2563EB',fillOpacity:0.15,weight:2,dashArray:'6 4'})
    .addTo(map)
    .bindPopup('<b style="font-family:monospace;font-size:11px">✏️ Custom Zone</b><br><span style="font-size:10px">User-drawn zone · Click to analyse</span>');
  drawnZones.push(poly);
  poly.openPopup();
  showToast('Zone drawn ✓ — click ANALYSE or select another mode');
  setMapMode('select', document.getElementById('mode-select'));
}

function onMeasureClick(e) {
  measurePoints.push([e.latlng.lat, e.latlng.lng]);
  const m = L.circleMarker(e.latlng,{radius:4,color:'#F59E0B',fillColor:'#F59E0B',fillOpacity:0.9}).addTo(map);
  measureMarkers.push(m);
  if(measureLine){map.removeLayer(measureLine);}
  if(measurePoints.length>1){
    measureLine = L.polyline(measurePoints,{color:'#F59E0B',weight:2,opacity:0.8}).addTo(map);
    const dist = measurePoints.reduce((acc,p,i)=>{
      if(i===0)return 0;
      return acc+map.distance(measurePoints[i-1],p);
    },0);
    document.getElementById('draw-tooltip').textContent=`Distance: ${(dist/1000).toFixed(2)} km · Double-click to finish`;
  }
}

function onMeasureFinish(e) {
  if(measurePoints.length<2)return;
  const dist = measurePoints.reduce((acc,p,i)=>i===0?0:acc+map.distance(measurePoints[i-1],p),0);
  showToast(`Measured distance: ${(dist/1000).toFixed(2)} km`);
  setMapMode('select', document.getElementById('mode-select'));
}

/* ═════════════════════════════════════
   POLICY SIMULATION
═════════════════════════════════════ */
function selectPolicy(id) {
  currentPolicy=id;
  renderPolicyDetail(id);
}

function enactPolicy(evt,id) {
  evt.stopPropagation();
  if(enactedPolicies.has(id)){selectPolicy(id);return;}
  enactedPolicies.add(id); enactedCount++;

  document.getElementById('badge-'+id).textContent='ENACTED';
  document.getElementById('badge-'+id).className='pc-badge b-enacted';
  document.getElementById('btn-'+id).textContent='✓ ENACTED';
  document.getElementById('btn-'+id).className='enact-btn done';
  document.getElementById('pc-'+id).classList.add('enacted');

  const epEl = v=>{ const e=document.getElementById(v); if(e)e.textContent=enactedCount; };
  epEl('s-ep'); epEl('hud-pol'); epEl('a-ep');
  document.getElementById('enacted-ct').textContent=enactedCount+' ENACTED';

  // Draw policy zone on map
  const p=policyData[id];
  if(p.zones && p.zones.length>=3){
    const poly=L.polygon(p.zones,{color:p.color,fillColor:p.color,fillOpacity:0.18,weight:2,dashArray:'7 4'})
      .addTo(map)
      .bindPopup(`<b style="font-family:monospace;font-size:11px">📋 ${p.name}</b><br><span style="font-size:10px;color:${p.color}">ENACTED · Policy Zone Active</span>`);
    activePolygons[id]=poly;
    map.panTo(p.zones[0],{animate:true,duration:0.5});
  }

  updateStats(id);
  buildRegistryTable(); // refresh with enacted status
  showToast('✓ Policy enacted: '+p.name);
  selectPolicy(id);
}

function renderPolicyDetail(id) {
  const p=policyData[id];
  const enacted=enactedPolicies.has(id);
  const factorBoxes=Object.values(p.factors).map(f=>`
    <div class="fbox"><div class="fb-label">${f.label}</div><div class="fb-val ${f.dir}">${f.val}</div><div class="fb-trend">${f.trend}</div></div>`).join('');
  const doneCnt=p.todos.filter(t=>t.done).length;
  const todos=p.todos.map((t,i)=>`
    <div class="todo-item ${t.done?'done':''}" onclick="toggleTodo(${id},${i})">
      <div class="todo-chk">${t.done?'✓':''}</div>
      <div style="flex:1"><div class="todo-txt">${t.txt}</div><div class="todo-meta">${t.zone}</div></div>
      <div class="todo-pri ${t.pri==='h'?'pri-h':t.pri==='m'?'pri-m':'pri-l'}">${t.pri==='h'?'HIGH':t.pri==='m'?'MED':'LOW'}</div>
    </div>`).join('');
  document.getElementById('rp-body').innerHTML=`
    <div class="apc-wrap">
      <div class="apc-hdr"><div class="apc-name">${p.name}</div><div class="apc-status">${enacted?'ENACTED':'DRAFT'}</div></div>
      <div class="factor-grid">${factorBoxes}</div>
    </div>
    <div class="todo-sec">
      <div class="todo-hdr"><div class="todo-title">Implementation Tasks</div><div class="todo-ct">${doneCnt}/${p.todos.length} DONE</div></div>
      ${todos}
    </div>
    <div class="llm-sec">
      <div class="llm-hdr"><div class="llm-ico">◈</div><div class="llm-label">UrbanPolicy AI Analysis</div></div>
      <div class="llm-out" id="llm-out">Click below to run simulation analysis via connected AI engine...</div>
      <button class="run-ai-btn" onclick="runPolicyAI(${id})">◈ RUN AI SIMULATION</button>
    </div>`;
}

function toggleTodo(pid,idx){
  policyData[pid].todos[idx].done=!policyData[pid].todos[idx].done;
  renderPolicyDetail(pid);
}

function updateStats(id) {
  if(id===1){animStat('s-walk',42,52);animStat('kpi-walk',42,52);}
  if(id===2){animStat('s-aqi',61,70);animStat('kpi-aqi',61,70);}
  if(id===3){animStat('s-tc',38,46,'%');animStat('kpi-transit',38,46,'%');}
  if(id===5){animStat('s-haf',29,36,'%');animStat('kpi-afford',29,36,'%');}
  if(id===6){animStat('s-co',4,14,'%',true);}
}

function animStat(id,from,to,suffix='',neg=false){
  const el=document.getElementById(id); if(!el)return;
  const steps=30,inc=(to-from)/steps; let cur=from,step=0;
  const iv=setInterval(()=>{
    cur+=inc;step++;
    if(step>=steps){cur=to;clearInterval(iv);}
    el.textContent=(neg?'-':'')+Math.round(Math.abs(cur))+suffix;
  },50);
}

/* ═════════════════════════════════════
   AI ENGINE — OLLAMA + ANTHROPIC
═════════════════════════════════════ */
function setBackend(b){
  aiBackend=b;
  document.getElementById('btn-backend-ollama').className='ai-backend-btn'+(b==='ollama'?' active-ollama active':'');
  document.getElementById('btn-backend-anthropic').className='ai-backend-btn'+(b==='anthropic'?' active':'');
  const input=document.getElementById('ai-conn-input');
  if(b==='ollama'){
    input.placeholder='Ollama base URL (e.g. http://localhost:11434)';
    input.value=ollamaBaseUrl!=='http://localhost:11434'?ollamaBaseUrl:'';
  } else {
    input.placeholder='Anthropic API key (sk-ant-...)';
    input.value='';
  }
  engineOnline=false;
  updateEngineUI('OFFLINE','badge-offline');
}

function connectEngine(){
  const val=document.getElementById('ai-conn-input').value.trim();
  if(!val){showToast('Enter URL or API key first');return;}
  if(aiBackend==='ollama'){
    ollamaBaseUrl=val.replace(/\/$/,'');
    testOllamaConnection(ollamaBaseUrl);
  } else {
    anthropicKey=val;
    engineOnline=true;
    updateEngineUI('CLAUDE ONLINE','badge-anthropic');
    addChatMsg('ai','✓ Anthropic Claude connected. I am ready to assist with Karachi urban planning analysis.');
    showToast('✓ Anthropic API connected');
  }
}

async function testOllamaConnection(url){
  updateEngineUI('CONNECTING...','badge-offline');
  addChatMsg('thinking','Connecting to Ollama at '+url+' ...');
  try {
    const resp=await fetch(url+'/api/tags',{method:'GET',signal:AbortSignal.timeout(5000)});
    if(!resp.ok)throw new Error('HTTP '+resp.status);
    const data=await resp.json();
    const models=(data.models||[]).map(m=>m.name).join(', ')||'(no models found)';
    engineOnline=true;
    // Try to pick user's first model or default to llama3
    if(data.models&&data.models.length>0){
      ollamaModel=data.models[0].name;
    }
    updateEngineUI('OLLAMA: '+ollamaModel.toUpperCase().slice(0,14),'badge-ollama');
    addChatMsg('ai','✓ Ollama connected at '+url+'. Available models: '+models+'. Using: '+ollamaModel+'. You can ask me to analyse any Karachi policy.');
    showToast('✓ Ollama connected — model: '+ollamaModel);
  } catch(e){
    updateEngineUI('OFFLINE','badge-offline');
    addChatMsg('ai','⚠ Could not connect to Ollama at '+url+'. Make sure:\n1. Ollama is running (ollama serve)\n2. CORS is enabled: set env OLLAMA_ORIGINS=* before starting\n3. Your finetuned model is pulled/loaded\nError: '+e.message);
  }
}

function updateEngineUI(label, badgeCls){
  const b=document.getElementById('model-badge');
  b.textContent=label; b.className='chat-model-badge '+badgeCls;
  document.getElementById('s-engine').textContent=label.split(':')[0];
  document.getElementById('engine-sub-label').textContent='URBANPOLICY AI · '+label;
  document.getElementById('engine-status-txt').textContent=label==='OFFLINE'?'OSM · ENGINE OFFLINE':'OSM · '+label;
}

async function callAI(messages){
  if(!engineOnline) throw new Error('No AI engine connected. Click CONNECT first.');
  if(aiBackend==='ollama') return callOllama(messages);
  return callAnthropic(messages);
}

async function callOllama(messages){
  // Format messages for Ollama /api/chat
  const payload={
    model: ollamaModel,
    messages: [
      {role:'system', content: SYSTEM_PROMPT},
      ...messages
    ],
    stream: false,
    options:{ temperature: 0.7, num_predict: 800 }
  };
  const resp=await fetch(ollamaBaseUrl+'/api/chat',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify(payload),
    signal:AbortSignal.timeout(60000)
  });
  if(!resp.ok){const e=await resp.text();throw new Error('Ollama error '+resp.status+': '+e.slice(0,200));}
  const data=await resp.json();
  return data.message?.content || data.response || '';
}

async function callAnthropic(messages){
  const resp=await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{
      'Content-Type':'application/json',
      'x-api-key':anthropicKey,
      'anthropic-version':'2023-06-01',
      'anthropic-dangerous-direct-browser-access':'true'
    },
    body:JSON.stringify({
      model:'claude-sonnet-4-20250514',
      max_tokens:1024,
      system:SYSTEM_PROMPT,
      messages
    })
  });
  if(!resp.ok){const e=await resp.json();throw new Error(e.error?.message||'API error '+resp.status);}
  const data=await resp.json();
  return data.content[0]?.text||'';
}

/* ─── Chat ─── */
function addChatMsg(role,text){
  const div=document.getElementById('chat-msgs');
  const el=document.createElement('div');
  el.className='chat-msg '+role;
  el.textContent=text;
  div.appendChild(el);
  div.scrollTop=div.scrollHeight;
  return el;
}

async function sendChat(){
  const input=document.getElementById('chat-input');
  const text=input.value.trim(); if(!text)return;
  input.value='';
  addChatMsg('user',text);
  chatHistory.push({role:'user',content:text});
  const thinking=addChatMsg('thinking','◈ thinking...');
  document.getElementById('chat-send-btn').disabled=true;

  try {
    const ctxNote = enactedCount>0
      ? ' [Enacted policies: '+Array.from(enactedPolicies).map(id=>policyData[id].name).join(', ')+']'
      : '';
    const msgs=[...chatHistory.slice(-8)];
    if(ctxNote&&msgs.length>0) msgs[msgs.length-1]={...msgs[msgs.length-1],content:msgs[msgs.length-1].content+ctxNote};
    const reply=await callAI(msgs);
    thinking.remove();
    addChatMsg('ai',reply);
    chatHistory.push({role:'assistant',content:reply});
  } catch(e){
    thinking.remove();
    addChatMsg('ai','Error: '+e.message);
  }
  document.getElementById('chat-send-btn').disabled=false;
}

/* ─── Run AI for policy simulation panel ─── */
async function runPolicyAI(id){
  const p=policyData[id];
  const el=document.getElementById('llm-out'); if(!el)return;
  el.innerHTML='<span class="llm-cursor"></span>';
  try {
    const txt=await callAI([{role:'user',content:`Simulate this Karachi urban policy for the UrbanPolicy platform: ${p.llmCtx}. Provide a 3-4 sentence simulation analysis with specific projected impacts, district-level effects, key risks, and a recommendation. Reference Karachi context.`}]);
    typeText(el,txt);
  } catch(e){
    // Fallback
    typeText(el,'Simulation: '+p.name+' is projected to deliver measurable impact across targeted Karachi districts. Connect the UrbanPolicy AI engine (Ollama or Anthropic) using the chat panel below for a live analysis powered by your finetuned model. Error: '+e.message);
  }
}

/* ─── Run AI for scenario cards ─── */
async function runScenarioAI(id,outEl){
  const sc=scenarioCards.find(s=>s.id===id); if(!sc)return;
  try {
    const txt=await callAI([{role:'user',content:`Simulate this Karachi urban scenario: ${sc.llmCtx}. Provide a 2-sentence result with key projected metric outcomes and Karachi-specific impacts.`}]);
    outEl.style.display='block';
    typeText(outEl,txt);
  } catch(e){
    outEl.style.display='block';
    outEl.textContent='Connect AI engine to see live simulation results. Projected: '+sc.metrics.map(m=>m.l+' '+m.v).join(' · ');
  }
}

/* ─── Reports AI ─── */
async function generateReport(){
  const title=document.getElementById('report-title-input').value||'Karachi Policy Impact Assessment';
  const type=document.getElementById('report-type-sel').value;
  const period=document.getElementById('report-period').value;
  const out=document.getElementById('report-gen-out');
  out.style.display='block';
  out.textContent='◈ Generating report with AI...';
  try {
    const enacted=enactedCount>0?Array.from(enactedPolicies).map(id=>policyData[id].name).join(', '):'No policies enacted yet';
    const txt=await callAI([{role:'user',content:`Generate a concise executive summary for a Karachi urban planning ${type} report titled "${title}" for period ${period}. Active policies: ${enacted}. Include 3-4 key findings with Karachi-specific metrics and a priority recommendation.`}]);
    typeText(out,txt);
    // Add to report list
    const newRep={
      id:'r-gen-'+Date.now(), name:title, type, date:new Date().toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}),
      pages:Math.floor(Math.random()*20+16), author:'Auto-Generated', status:'ready',
      exec:txt.slice(0,280)+'...', findings:'Generated via UrbanPolicy AI engine.',
      metrics:[{k:'Walkability',v:document.getElementById('s-walk').textContent,c:'#10B981'},{k:'AQI',v:document.getElementById('s-aqi').textContent,c:'#EF4444'},{k:'Transit',v:document.getElementById('s-tc').textContent,c:'#60A5FA'}]
    };
    reportStore.unshift(newRep);
    buildReportList();
    showToast('✓ Report generated: '+title);
  } catch(e){
    out.textContent='Error: '+e.message+'. Connect AI engine first.';
  }
}

async function generateLLMSection(){
  const out=document.getElementById('llm-report-out');
  out.style.display='block';
  const title=document.getElementById('rp-title-display').textContent;
  const exec=document.getElementById('rp-exec-text').textContent;
  out.textContent='◈ Generating AI analysis...';
  try {
    const txt=await callAI([{role:'user',content:`Write a 3-sentence AI policy analysis for this Karachi urban planning report: "${title}". Summary: ${exec.slice(0,300)}. Provide insights on policy effectiveness, Karachi-specific risks, and strategic recommendations.`}]);
    typeText(out,txt);
  } catch(e){
    out.textContent='Error: '+e.message+'. Connect AI engine to generate live analysis.';
  }
}

async function submitScenario(){
  const name=document.getElementById('sc-name-input').value||'Custom Scenario';
  const horizon=document.getElementById('sc-horizon').value;
  const objective=document.getElementById('sc-objective').value;
  const budget=document.getElementById('sc-budget').value;
  const desc=document.getElementById('sc-desc-input').value;
  const popW=document.getElementById('sl-pop').value;
  const envW=document.getElementById('sl-env').value;
  const eqW=document.getElementById('sl-eq').value;
  const out=document.getElementById('sc-submit-out');
  out.style.display='block';
  out.textContent='◈ Running scenario simulation...';
  try {
    const txt=await callAI([{role:'user',content:`Simulate this Karachi urban planning scenario: "${name}". Horizon: ${horizon}. Primary objective: ${objective}. Budget cap: ${budget?'PKR '+budget+'B':'unlimited'}. Priorities: Population Growth ${popW}%, Environmental ${envW}%, Equity ${eqW}%. Description: ${desc||'No additional details.'}. Provide projected outcomes across walkability, housing, AQI, transit and equity metrics with specific numbers and implementation recommendations for Karachi.`}]);
    typeText(out,txt);
    showToast('✓ Scenario simulation complete');
  } catch(e){
    out.textContent='Error: '+e.message+'. Connect AI engine for live simulation.';
  }
}

/* ═════════════════════════════════════
   UI BUILDERS
═════════════════════════════════════ */
function buildRegistryTable(){
  const tbody=document.getElementById('registry-tbody'); if(!tbody)return;
  tbody.innerHTML=registryData.map(r=>{
    const enacted=[...enactedPolicies].some(id=>policyData[id].name===r.name);
    const statCls=enacted?'tag-g':'tag-b';
    const statTxt=enacted?'ENACTED':'DRAFT';
    return `<tr>
      <td>${r.name}</td>
      <td><span class="tag ${r.catCls}">${r.cat}</span></td>
      <td><span class="tag ${statCls}">${statTxt}</span></td>
      <td style="color:#10B981">${r.walkDelta}</td>
      <td style="color:#60A5FA">${r.aqiDelta}</td>
      <td style="color:#10B981">${r.housingDelta}</td>
      <td style="color:#10B981">${r.carbonDelta}</td>
      <td><div class="impact-bar-wrap"><div class="impact-bar" style="width:${r.impact}%;background:${r.impact>80?'#10B981':r.impact>60?'#F59E0B':'#EF4444'}"></div></div></td>
    </tr>`;
  }).join('');
}

function buildScenarioCards(){
  document.getElementById('sc-grid').innerHTML=scenarioCards.map(sc=>`
    <div class="sc-card ${sc.cls}" id="sc-${sc.id}">
      <div class="sc-name">${sc.name}</div>
      <div class="sc-desc">${sc.desc}</div>
      <div class="sc-meta-row">${sc.tags.map(t=>`<span class="sc-tag">${t}</span>`).join('')}</div>
      <div class="sc-metrics">${sc.metrics.map(m=>`<div class="sc-metric"><div class="sc-metric-label">${m.l}</div><div class="sc-metric-val" style="color:${m.c}">${m.v}</div></div>`).join('')}</div>
      <button class="sc-run-btn" id="sc-btn-${sc.id}" onclick="runScenario(${sc.id},this)">▶ RUN SIMULATION</button>
      <div class="progress-bar"><div class="progress-fill" id="sc-prog-${sc.id}"></div></div>
      <div class="sc-llm-out" id="sc-llm-${sc.id}"></div>
    </div>`).join('');
}

function runScenario(id,btn){
  const card=document.getElementById('sc-'+id);
  if(btn.classList.contains('running'))return;
  btn.textContent='◈ SIMULATING...'; btn.classList.add('running'); card.classList.add('running');
  let pct=0;
  const iv=setInterval(()=>{
    pct+=Math.random()*7+2;
    if(pct>=100){
      pct=100; clearInterval(iv);
      btn.textContent='✓ SIMULATION COMPLETE'; btn.classList.remove('running'); card.classList.remove('running');
      showToast('✓ Scenario simulation complete');
      const outEl=document.getElementById('sc-llm-'+id);
      runScenarioAI(id,outEl);
    }
    document.getElementById('sc-prog-'+id).style.width=Math.min(pct,100)+'%';
  },180);
}

function buildReportList(){
  document.getElementById('report-list').innerHTML=reportStore.map(r=>`
    <div class="report-item" onclick="previewReport('${r.id}')">
      <div class="report-ico ${r.type.includes('Environ')?'ri-green':r.type.includes('Cost')?'ri-amber':r.type.includes('Equity')?'ri-purple':'ri-blue'}">${r.type.includes('Environ')?'🌿':r.type.includes('Cost')?'📊':r.type.includes('Equity')?'⚖️':'📋'}</div>
      <div class="report-content">
        <div class="report-name">${r.name}</div>
        <div class="report-meta"><span>${r.date}</span><span>·</span><span>${r.pages} PAGES</span><span>·</span><span>${r.author}</span><span>·</span><span>${r.type}</span></div>
      </div>
      <div class="report-status ${r.status==='ready'?'rs-ready':r.status==='generating'?'rs-gen':'rs-draft'}">${r.status.toUpperCase()}</div>
      <div class="report-actions">
        <button class="r-btn" onclick="event.stopPropagation();previewReport('${r.id}')">PREVIEW</button>
        <button class="r-btn primary" onclick="event.stopPropagation();exportReport('${r.name}')">EXPORT</button>
      </div>
    </div>`).join('');
}

function openReportModal(){ openModal('report-modal'); }

function createReport(){
  const title=document.getElementById('modal-report-title').value||'Karachi Policy Report';
  const type=document.getElementById('modal-report-type').value;
  const author=document.getElementById('modal-author').value||'Planning Department';
  closeModal('report-modal');
  const newRep={
    id:'r-m-'+Date.now(), name:title, type, date:new Date().toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}),
    pages:24, author, status:'draft',
    exec:'This '+type+' for "'+title+'" is currently in draft. Use the AI ANALYSIS button to generate a full executive summary.',
    findings:'Findings will be populated upon AI analysis completion.',
    metrics:[{k:'Walkability',v:document.getElementById('s-walk').textContent,c:'#10B981'},{k:'AQI',v:document.getElementById('s-aqi').textContent,c:'#EF4444'},{k:'Transit',v:document.getElementById('s-tc').textContent,c:'#60A5FA'}]
  };
  reportStore.unshift(newRep);
  buildReportList();
  showToast('✓ Report created: '+title);
  previewReport(newRep.id);
}

function previewReport(id){
  const r=reportStore.find(rep=>rep.id===id); if(!r)return;
  document.getElementById('rp-title-display').textContent=r.name;
  document.getElementById('rp-meta-display').textContent='KARACHI METRO · '+r.date.toUpperCase()+' · '+r.pages+' PAGES · '+r.author.toUpperCase();
  document.getElementById('rp-exec-text').textContent=r.exec;
  document.getElementById('rp-findings-text').textContent=r.findings;
  const llmOut=document.getElementById('llm-report-out');
  llmOut.style.display='none'; llmOut.textContent='Click "◈ AI ANALYSIS" to generate.';
  document.getElementById('rp-metrics-list').innerHTML=r.metrics.map(m=>`
    <div class="rcp-metric"><div class="rcp-metric-name">${m.k}</div><div class="rcp-metric-val" style="color:${m.c}">${m.v}</div></div>`).join('');
  const prev=document.getElementById('report-preview');
  prev.style.display='block';
  prev.scrollIntoView({behavior:'smooth'});
}

function exportReport(name){
  showToast('Exporting "'+( name||'Report')+'" as PDF... (integrate with server-side PDF export)');
}

